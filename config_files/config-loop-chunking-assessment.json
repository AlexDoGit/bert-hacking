{
    "datasets":[
        {
            "filepath-train": "./data/ideology_news-dataset_for_training_400_50.csv",
            "name": "ideology_news-chunked-400-50-chunk-assessment",
            "text_col": "content",
            "label_col": "bias_text",
            "id_col": "ID",
            "id_chunk_col": "ID-chunk",
            "filepath-predict": "./data/ideology_news-dataset_for_inference_400_50-small.csv",
            "extra_cols_to_keep" : ["year"]
        }
    ],
    "data-hyperparameters":{
        "N_annotated": [
            1000, 
            2000
        ],
        "splits_ratio": [
            [70, 15, 15]
        ],
        "sampling_method" : [
            {"balance":"random"},
            {"balance":0.50},
            {"balance":"random", "stratified": "year"},
            {"balance":0.50    , "stratified": "year"}
        ]
    },
    "model-hyperparameters":{
        "model_name": [
            "google-bert/bert-base-uncased"
        ],
        "learning_rate":[
            1e-4,
            1e-5, 
            5e-5
        ],
        "weight_decay":[
            0.0,
            0.01
        ], 
        "batch_size":[16]
    }
}